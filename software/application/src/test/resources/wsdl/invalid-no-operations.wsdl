<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
                  xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
                  xmlns:tns="http://example.com/empty"
                  targetNamespace="http://example.com/empty"
                  name="EmptyService">
  <wsdl:types/>
  <wsdl:portType name="EmptyPortType"/>
  <wsdl:binding name="EmptyBinding" type="tns:EmptyPortType">
    <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
  </wsdl:binding>
  <wsdl:service name="EmptyService">
    <wsdl:port name="EmptyPort" binding="tns:EmptyBinding">
      <soap:address location="http://example.com/empty"/>
    </wsdl:port>
  </wsdl:service>
</wsdl:definitions>

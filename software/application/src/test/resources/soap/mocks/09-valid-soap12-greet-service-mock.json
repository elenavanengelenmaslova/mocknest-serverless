{
  "request": {
    "method": "POST",
    "urlPath": "/GreetService",
    "headers": {
      "Content-Type": {
        "contains": "action=\"http://example.com/greet/Greet\""
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/soap+xml; charset=utf-8"
    },
    "body": "<?xml version=\"1.0\" encoding=\"utf-8\"?><soap12:Envelope xmlns:soap12=\"http://www.w3.org/2003/05/soap-envelope\"><soap12:Body><GreetResponse xmlns=\"http://example.com/greet\"><Message>Greetings!</Message></GreetResponse></soap12:Body></soap12:Envelope>"
  },
  "persistent": true
}

{
  "id": "demo-environment",
  "name": "Demo Example",
  "values": [
    {
      "key": "AWS_URL",
      "value": "https://{{API_ID}}.execute-api.{{AWS_REGION}}.amazonaws.com/prod",
      "description": "AWS API Gateway endpoint URL (uses API_ID and AWS_REGION variables)",
      "enabled": true
    },
    {
      "key": "API_ID",
      "value": "your-api-id",
      "description": "AWS API Gateway API ID (get from CloudFormation outputs after deployment)",
      "enabled": true
    },
    {
      "key": "api_key",
      "value": "your-api-key-here",
      "description": "AWS API Gateway API key",
      "enabled": true
    },
    {
      "key": "AWS_REGION",
      "value": "eu-west-1",
      "description": "AWS region where MockNest is deployed (default: eu-west-1)",
      "enabled": true
    }
  ]
}
{
  "info": {
    "name": "Health Checks",
    "description": "Collection for running health checks on MockNest Serverless",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "AWS Health Check",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{api_key}}"
          }
        ],
        "url": {
          "raw": "{{AWS_URL}}/__admin/health",
          "host": ["{{AWS_URL}}"],
          "path": ["__admin", "health"]
        }
      }
    }
  ]
}
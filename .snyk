# Snyk configuration file
# https://docs.snyk.io/snyk-cli/test-for-vulnerabilities/the-.snyk-file

# Scan all Gradle submodules
gradle:
  allProjects: true

# Exclude test dependencies from vulnerability reporting (optional)
exclude:
  development: true

# Enable Snyk Code (SAST) scanning
code:
  enabled: true

# Enable Infrastructure as Code (IaC) scanning
iac:
  enabled: true
